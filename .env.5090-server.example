# 5090 server node template
# Mine only. Do not put Telegram bot credentials on worker nodes.

PRL_ADDRESS='prl1pYOURADDRESS'
PRL_MINER_BINARY='~/prl-local-test/alpha-miner'

# Leave PRL_WORKER unset to auto-use the server hostname,
# or set it explicitly if you prefer a custom name.
# PRL_WORKER='gpu-node-01'

# Use the closest endpoint for the server region.
PRL_POOL='stratum+tcp://eu1.alphapool.tech:5566'

# 5090 / Blackwell recommendation from AlphaPool setup.
PRL_FORCE_BACKEND='blackwell'
PRL_PASSWORD='x;d=1048576'

# Omit PRL_DEVICES to use every GPU in the server.
# PRL_DEVICES='0,1,2,3'

PRL_STATUS_INTERVAL='60'
PRL_POLL_INTERVAL='30'
PRL_STATE_FILE='.prl-watch-state.json'

# Keep a thermal guard. Do not cap power here unless you want efficiency mode.
PRL_MAX_TEMP_C='82'
PRL_GPU_REPORT_INTERVAL='60'
PRL_GPU_CHECK_INTERVAL='5'
