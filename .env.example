# Pearl / AlphaPool controller node config
# Keep the real .env local. Commit only .env.example variants.

# Required
PRL_ADDRESS='prl1pYOURADDRESS'
PRL_MINER_BINARY='~/prl-local-test/alpha-miner'
PRL_WORKER='local-rig'

# Optional Telegram alerts / central bot
TG_BOT_TOKEN='123456:replace-me'
TG_CHAT_ID='123456789'
TG_STATUS_INTERVAL_MINUTES='60'

# Pool / miner settings
PRL_POOL='stratum+tcp://eu1.alphapool.tech:5566'
PRL_DEVICES='0'
PRL_FORCE_BACKEND='ada'
PRL_PASSWORD=''

# Wrapper settings
PRL_STATUS_INTERVAL='60'
PRL_POLL_INTERVAL='30'
PRL_STATE_FILE='.prl-watch-state.json'
PRL_NOTIFY_CONTRIBUTED='1'

# Local safety profile
PRL_MAX_TEMP_C='78'
PRL_MAX_POWER_W='190'
PRL_GPU_REPORT_INTERVAL='60'
PRL_GPU_CHECK_INTERVAL='5'
