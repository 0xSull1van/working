# PRL Watch / AlphaPool — environment template.
#
# Copy to ".env" (gitignored) and fill in your values.
# Each prl_watch.py command reads these as defaults; CLI flags override.

# --- core (required) ---
PRL_ADDRESS=prl1pYOURADDRESS
TG_BOT_TOKEN=123456:YOURBOTTOKEN
TG_CHAT_ID=123456789

# --- mining server (only needed on rigs running `run` or `serve`) ---
# path to alpha-miner binary
PRL_MINER_BINARY=./alpha-miner
# stratum endpoint. EU: eu1.alphapool.tech, US: us2.alphapool.tech. Solo port :5567, pool port :5566.
PRL_POOL=stratum+tcp://eu1.alphapool.tech:5566
# worker name; defaults to hostname if unset
# PRL_WORKER=rig01
# optional: explicit GPU list and Blackwell-native backend for RTX 5090
# PRL_DEVICES=0,1,2,3
# PRL_FORCE_BACKEND=blackwell-native
# optional password used by alpha-miner; difficulty hint
# PRL_PASSWORD=x;d=65536

# --- safety guards (rigs) ---
# PRL_MAX_TEMP_C=80
# PRL_MAX_POWER_W=450
# PRL_GPU_REPORT_INTERVAL=60
# PRL_GPU_CHECK_INTERVAL=5

# --- hub / bot tuning ---
# poll AlphaPool every N seconds (default 30)
# PRL_POLL_INTERVAL=30
# send periodic /status to Telegram every N minutes (0 disables)
TG_STATUS_INTERVAL_MINUTES=60
# notify on every block where your address contributed shares (not only finder)
# PRL_NOTIFY_CONTRIBUTED=false
# notify on new/returning workers (default true)
# PRL_NOTIFY_WORKERS=true
# notify when a worker drops offline (default true)
# PRL_NOTIFY_OFFLINE=true

# --- /earnings price hint ---
# set this so /earnings can show net USD/day
# PRL_PRICE_USD=0.36
# alpha-miner dev fee percent (default 1.0 for alpha-miner)
# PRL_MINER_FEE_PERCENT=1.0
